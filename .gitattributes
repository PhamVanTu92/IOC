# ─────────────────────────────────────────────────────────────────────────────
# Git line ending normalization
# ─────────────────────────────────────────────────────────────────────────────

# Default: normalize to LF on commit
* text=auto eol=lf

# Shell scripts MUST be LF (breaks on Linux if CRLF)
*.sh   text eol=lf
*.bash text eol=lf

# Windows-specific files keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.ps1  text eol=crlf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pdf  binary
*.zip  binary
