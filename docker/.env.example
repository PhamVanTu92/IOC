# ─────────────────────────────────────────────────────────────────────────────
# IOC Platform — Production Environment Variables
# Copy file này thành .env rồi điền giá trị thực
# cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ioc_prod
POSTGRES_USER=ioc
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Backend ───────────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production

# Ports expose ra ngoài server
BACKEND_PORT=5000
FRONTEND_PORT=80
